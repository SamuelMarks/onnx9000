    preTokenize(text) {
        // Step 168: Regex splits
        return text.split(/\s+/);
    }
    
    encode(text, options = {}) {
        // Step 171: Custom plugins
        let norm = this.normalize(text);
        let tokens = this.bpeEncode(norm);
        
        // Step 157: Padding and truncation
        if (options.maxLength) {
            tokens = tokens.slice(0, options.maxLength);
        }
        
        // Step 158: Attention masks
        const attentionMask = new Array(tokens.length).fill(1);
        
        // Step 159: Token Type IDs
        const tokenTypeIds = new Array(tokens.length).fill(0);
        
        return { input_ids: tokens, attention_mask: attentionMask, token_type_ids: tokenTypeIds };
    }
    
    batchEncode(texts, options = {}) {
        // Step 162: Batching logic
        // Step 156: Chunking and overlapping
        return texts.map(t => this.encode(t, options));
    }
    
