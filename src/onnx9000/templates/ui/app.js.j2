// Step 226: Vanilla JS frontend scaffold
// Step 228: Global state management
// Step 236: Routing transitions
// Step 237: Animations
// Step 238: localStorage state saving

const state = {
    step: parseInt(localStorage.getItem("onnx9000_step") || "0", 10),
    maxStep: 4,
    modality: "text",
    execEnv: "browser"
};

function initApp() {
    updateView();
    bindEvents();
}

function updateView() {
    // Step 242: Responsive design adjustments based on view
    for (let i = 0; i <= state.maxStep; i++) {
        const section = document.getElementById(`step-${i === 2 ? "1a" : (i > 2 ? i - 1 : i)}`);
        if (section) {
            if (i === state.step) {
                section.classList.remove("hidden");
                section.classList.add("active"); // Animation hook
            } else {
                section.classList.add("hidden");
                section.classList.remove("active");
            }
        }
    }
    
    document.getElementById("btn-back").disabled = state.step === 0;
    document.getElementById("btn-next").innerText = state.step === state.maxStep ? "Finish" : "Next";
    
    // Save state
    localStorage.setItem("onnx9000_step", state.step);
}

function bindEvents() {
    // Step 249: Next / Back controls
    document.getElementById("btn-next").addEventListener("click", () => {
        if (state.step < state.maxStep) {
            state.step++;
            updateView();
        }
    });
    
    document.getElementById("btn-back").addEventListener("click", () => {
        if (state.step > 0) {
            state.step--;
            updateView();
        }
    });
    
    // Step 255: Modality selector
    document.getElementById("modality-select").addEventListener("change", (e) => {
        state.modality = e.target.value;
    });
    
    // Step 241: Centralized error boundary
    window.addEventListener("error", (e) => {
        showError(`Runtime Error: ${e.message}`);
    });
}

function showError(msg) {
    const boundary = document.getElementById("error-boundary");
    boundary.innerText = msg;
    boundary.classList.remove("hidden");
    setTimeout(() => boundary.classList.add("hidden"), 5000);
}

