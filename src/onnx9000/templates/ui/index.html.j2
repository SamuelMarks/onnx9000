<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ml-switcheroo | ONNX9000 Stepper</title>
    <link rel="stylesheet" href="style.css">
    <!-- Google Fonts & Material Symbols for Vanilla M3 -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Symbols+Outlined" rel="stylesheet">
</head>
<body>
    <div id="app" class="m3-theme-light">
        <header class="stepper-header">
            <h1 class="title">ml-switcheroo | in-browser training</h1>
            <nav id="stepper-nav" aria-label="Progress"></nav>
        </header>
        <div id="error-boundary" class="hidden error-banner" aria-live="assertive"></div>

        <main id="step-content">
            <section id="step-0" class="step-section active">
                <h2>Step 0: Model Definition</h2>
                <div id="code-editor" class="code-container">
                    <pre><code>
import onnx9000
@onnx9000.jit
def demo_model(x, w):
    return onnx9000.ops.relu(x @ w)
                    </code></pre>
                </div>
                <div id="dag-viewer" class="dag-container">DAG Viewer Placeholder</div>
            </section>

            <section id="step-1" class="step-section hidden">
                <h2>Step 1: Modality Selection</h2>
                <div class="split-view">
                    <div class="left-pane">
                        <select id="modality-select" class="m3-select" aria-label="Modality">
                            <option value="text">Text (LLM)</option>
                            <option value="image">Image (Vision)</option>
                            <option value="video">Video</option>
                        </select>
                        <div id="modality-config"></div>
                    </div>
                    <div class="right-pane" id="step1-dag-view"></div>
                </div>
            </section>

            <section id="step-1a" class="step-section hidden">
                <h2>Step 1a: Execution Config</h2>
                <div class="exec-toggle">
                    <label><input type="radio" name="exec-env" value="local"> Local / Server</label>
                    <label title="Note: WebGPU uses 4GB max memory"><input type="radio" name="exec-env" value="browser" checked> In-Browser (WebGPU)</label>
                </div>
                <div id="dataset-upload" class="dropzone" aria-label="Dataset Dropzone">
                    <p>Drag and drop dataset folder here</p>
                </div>
                <form id="hyperparams-form">
                    <input type="number" id="lr" placeholder="Learning Rate" value="0.001">
                    <input type="number" id="batch" placeholder="Batch Size" value="32">
                </form>
            </section>

            <section id="step-2" class="step-section hidden">
                <h2>Step 2: Compilation & Logs</h2>
                <div class="progress-bars">
                    <progress id="weight-progress" value="0" max="100"></progress>
                    <progress id="compile-progress" value="0" max="100"></progress>
                </div>
                <div id="terminal-container" class="terminal"></div>
                <div id="training-charts" class="charts"></div>
                <div class="controls">
                    <button id="btn-pause">Pause</button>
                    <button id="btn-export-logs">Export Logs</button>
                    <button id="btn-download-model">Download Compiled Model</button>
                </div>
            </section>

            <section id="step-3" class="step-section hidden">
                <h2>Step 3: Live Dashboard</h2>
                <div id="live-inputs">
                    <textarea id="live-text-input" placeholder="Enter text..."></textarea>
                    <button id="btn-infer">Run Inference</button>
                </div>
                <div id="live-outputs"></div>
                <div class="metrics" id="latency-overlay">Latency: -- ms</div>
                <div class="actions">
                    <button id="btn-toggle-train">Continuous Training: OFF</button>
                    <button id="btn-save-weights">Save Weights</button>
                    <button id="btn-download-trained">Download .onnx</button>
                </div>
            </section>
        </main>

        <footer class="stepper-controls">
            <button id="btn-back" class="m3-button secondary" disabled>Back</button>
            <button id="btn-next" class="m3-button primary">Next</button>
        </footer>

        <div id="toast-container" class="toast-container" aria-live="polite"></div>
    </div>
    <script src="app.js"></script>
</body>
</html>
