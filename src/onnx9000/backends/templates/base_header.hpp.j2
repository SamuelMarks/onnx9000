/**
 * @brief Macro for N-dimensional flat index calculation.
 * @tparam Args Variadic template arguments for indices.
 * @param strides The strides of the tensor.
 * @param args The indices.
 * @return The flat index.
 */
template <typename... Args>
inline int64_t calc_index(const std::vector<int64_t>& strides, Args... args) noexcept {
    const int64_t indices[] = {static_cast<int64_t>(args)...};
    int64_t offset = 0;
    for (size_t i = 0; i < sizeof...(Args); ++i) {
        offset += indices[i] * strides[i];
    }
    return offset;
}

/**
 * @brief Flat index calculation given a vector of indices
 * @param strides The strides of the tensor.
 * @param indices The indices.
 * @return The flat index.
 */
inline int64_t calc_index_vec(const std::vector<int64_t>& strides,
                              const std::vector<int64_t>& indices) noexcept {
    int64_t offset = 0;
    for (size_t i = 0; i < strides.size(); ++i) {
        offset += indices[i] * strides[i];
    }
    return offset;
}

/**
 * @brief Base Tensor struct representing memory layout
 * @tparam T The data type.
 */
template <typename T>
struct Tensor {
    T* data;                     ///< Pointer to data buffer
    std::vector<int64_t> shape;  ///< Tensor shape
    std::vector<int64_t> strides;///< Tensor strides

    /**
     * @brief Constructs a Tensor from a pointer and a shape.
     * @param ptr The data pointer.
     * @param s The shape vector.
     */
    Tensor(T* ptr, const std::vector<int64_t>& s) noexcept : data(ptr), shape(s) {
        try {
            strides.resize(shape.size());
            int64_t stride = 1;
            for (int i = static_cast<int>(shape.size()) - 1; i >= 0; --i) {
                strides[i] = stride;
                stride *= shape[i];
            }
        } catch (...) {
            // Silently fail to keep noexcept guarantee
        }
    }

    /**
     * @brief Gets total elements.
     * @return Total size.
     */
    int64_t size() const noexcept {
        if (shape.empty()) return 1;
        int64_t sz = 1;
        for (auto d : shape) sz *= d;
        return sz;
    }
};

/**
 * @brief Safe absolute value function that avoids ambiguous calls on unsigned types.
 * @tparam T The data type.
 * @param x The input value.
 * @return The absolute value.
 */
template <typename T>
inline auto safe_abs(T x) noexcept -> T {
    if constexpr (std::is_unsigned_v<T>) {
        return x;
    } else {
        return std::abs(x);
    }
}

