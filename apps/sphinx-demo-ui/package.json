{
  "name": "@onnx9000/sphinx-demo-ui",
  "version": "1.0.0",
  "description": "Vanilla JS frontend for Sphinx integrated WASM demo",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "docs": "typedoc --out docs src",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"**/*.css\""
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cytoscape": "^3.31.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.50.0",
    "eslint-plugin-import": "^2.29.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@onnx9000/c-compiler": "workspace:^",
    "@onnx9000/converters": "workspace:^",
    "@onnx9000/core": "workspace:^",
    "@onnx9000/coreml": "workspace:^",
    "@onnx9000/iree-compiler": "workspace:^",
    "@onnx9000/optimum": "workspace:^",
    "cytoscape": "^3.33.1",
    "monaco-editor": "^0.47.0"
  }
}
