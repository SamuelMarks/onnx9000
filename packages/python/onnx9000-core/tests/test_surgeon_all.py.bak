import pytest
import onnx9000.core.surgeon as surgeon
from onnx9000.core.ir import Graph, Node, Tensor, Variable, Constant, Attribute, DynamicDim
from onnx9000.core.dtypes import DType

def test_surgeon_all():
    g = Graph("test")
    v1 = Variable("in1")
    v2 = Variable("in2")
    g.add_tensor(v1)
    g.add_tensor(v2)
    
    c = Constant("c", values=b"abc", shape=(3,), dtype=DType.FLOAT32)
    g.add_tensor(c); g.promote_to_output(c)

    n1 = Node("Add", inputs=[v1, v2], outputs=[g.register_output("out1", (), DType.FLOAT32)])
    g.add_node(n1)

    # Topology and traversal
    g.toposort()
    g.cleanup()
    g.fold_constants()
    g.simplify()

    # prev_nodes, next_nodes
    assert n1.prev_nodes == []
    assert n1.next_nodes == []

    # get_nodes
    assert len(g.get_nodes_by_op("Add")) == 1
    assert len(g.get_nodes_by_name_regex(".*")) == 1
    assert len(g.get_nodes_by_op_regex(".*")) == 1
    assert len(g.get_tensors_by_name_regex(".*")) == 4
    assert len(g.get_nodes_by_domain("")) == 1

    # find_path
    assert g.find_path(n1, n1) == [n1]
    assert g.find_all_paths(n1, n1) == [[n1]]
    
    # disconnected components
    comps = g.get_disconnected_components()
    assert len(comps) == 1

    # extract_subgraph
    subg = g.extract_subgraph([n1])
    assert len(subg.nodes) == 1
    
    # isolate_dependencies
    isolated = g.isolate_dependencies(g.tensors["out1"])
    assert len(isolated.nodes) == 1

    # Profiling
    assert g.analyze_critical_path() == [n1]
    assert g.estimate_macs() == 0
    assert g.estimate_constant_memory() == 3
    assert g.estimate_activation_memory() == 12

    # Graph surgery
    n2 = Node("Mul", inputs=[v1], outputs=[Variable("out2")])
    g.append_node(n2)
    
    n3 = Node("Div", inputs=[v1], outputs=[Variable("out3")])
    g.insert_node(0, n3)
    
    g.disconnect_node(n2)
    g.remove_node(n3)
    
    n4 = Node("Sub", inputs=[v1], outputs=[g.register_output("out4", (), DType.FLOAT32)])
    g.replace_node(n1, n4)

    # node modifications
    n4.disconnect_input(v1)
    n4.disconnect_output(g.tensors["out4"])
    n4.replace_input(v2, v1)
    n4.replace_output(v2, v1)

    # node edge injection
    g.add_node(n4) # re-add
    v_out4 = g.tensors.get("out4", g.register_output("out4", (), DType.FLOAT32))
    if "out4" not in g.tensors: g.add_tensor(v_out4)
    n4.outputs = [v_out4]
    
    n_consumer = Node("Cast", inputs=[v_out4], outputs=[Variable("out5")])
    g.add_node(n_consumer)
    
    n_new = Node("Exp")
    g.inject_node_on_edge(n4, n_consumer, n_new, 0)
    
    g.bypass_node(n_new)
    
    # variable/constant conversion
    c2 = g.variable_to_constant(v1, b"xyz")
    v3 = g.constant_to_variable(c)

    # fusion / split
    n_fuse1 = Node("A", inputs=[v1], outputs=[Variable("a_out")])
    n_fuse2 = Node("B", inputs=[n_fuse1.outputs[0]], outputs=[Variable("b_out")])
    g.add_node(n_fuse1)
    g.add_node(n_fuse2)
    g.fuse_nodes([n_fuse1, n_fuse2], Node("Fused"))

    n_to_split = Node("ToSplit", inputs=[v1], outputs=[Variable("split_out")])
    g.add_node(n_to_split)
    g.split_node(n_to_split, [Node("Split1"), Node("Split2")])

    # append / prepend
    g_other = Graph("other")
    g_other.add_tensor(Variable("otherv"))
    g.append_graph(g_other, {})
    g.prepend_graph(g_other, {})

    # Inputs / Outputs manipulation
    v_new = g.register_input("global_in", (), DType.FLOAT32)
    v_out_new = g.register_output("global_out", (), DType.FLOAT32)
    g.reorder_inputs(["global_in"])
    g.reorder_outputs(["global_out"])
    g.remove_input("global_in")
    g.remove_output("global_out")

    # Rename
    g.rename_op("Fused", "Fused2")
    g.rename_domain("", "mydomain")
    
    # Probes
    g.inject_identity_probe(v1)
    g.remove_all_identity()
    
    # Output promote
    g.promote_to_output(v1)
    g.demote_output(v1.name)
    g.promote_constant_to_input(c2)

    # duplicate
    g.duplicate_subgraph([n4], "prefix")

    # matcher
    matcher = surgeon.PatternMatcher(op_type="Sub")
    matches = g.match_pattern(matcher)
    assert len(matches) >= 1
    g.replace_pattern(matcher, lambda n: [Node("SubRep")])

    # complex matcher
    m_inputs = [surgeon.PatternMatcher(op_type="A"), lambda t: True]
    m_complex = surgeon.PatternMatcher(op_type="B", inputs=m_inputs, unordered=True)
    g.match_pattern(m_complex)
    m_complex2 = surgeon.PatternMatcher(op_type="B", inputs=m_inputs, unordered=False)
    g.match_pattern(m_complex2)
    m_complex3 = surgeon.PatternMatcher(op_type="B", is_constant=True)
    g.match_pattern(m_complex3)

    # fusions
    g.fold_constants_math()
    g.fold_constants_shape()
    g.eliminate_dropout()
    g.eliminate_cast()
    g.sink_transposes()
    g.convert_layout()
    g.infer_shapes()
    g.infer_symbolic_shapes()
    g.infer_dtypes()
    g.fuse_conv_bn()
    g.fuse_conv_add()
    g.fuse_conv_mul()
    g.fuse_matmul_add()
    g.fuse_gemm_relu()
    g.fuse_conv_relu()
    g.fuse_sequential_reshapes()
    g.strip_doc_strings()
    g.minification()
    g.deduplicate_constants()

    g.cancel_squeeze_unsqueeze()
    g.cancel_split_concat()
    g.cancel_pad_slice()
    g.fuse_gelu_erf()
    g.fuse_gelu_tanh()
    g.fuse_layer_norm()
    g.fuse_attention()
    g.fuse_rope()
    g.fuse_group_norm()
    g.downcast_float64_float32()
    g.downcast_float32_float16()
    g.downcast_int64_int32()
    g.quantize_static_int8()
    g.quantize_weight_int8()
    g.quantize_weight_int4()

    # IO
    g.load_external_data("dir")
    g.export_raw_bytes()
    g.memory_view_bridge()
    g.chunk_constants()
    g.dump_netron_json()
    g.validate_topology()
    g.upgrade_opset(15)
    n4.upgrade_opset(15)
    n4.downgrade_opset(15)
    g.validate_types_and_shapes()
    g.semantic_equivalence(g)
    g.dump_txt()
    g.export_external_data("dir")

    # Trt
    g.inject_quantize_nodes({})
    g.fuse_fake_quantize()
    g.unfuse_fake_quantize()
    g.inject_trt_plugin("plug", {"k": 1})
    g.convert_nms_trt()
    g.convert_resize_trt()
    g.convert_topk_trt()
    g.enforce_precision_bounds()
    g.inject_trt_calibration()

    # Constants
    c3 = Constant("c3", shape=(2,2), values=b"1234123412341234")
    c3.transpose([1,0])
    c3.reshape((4,))
    c3.broadcast((2,2,2))
    
    # Broadcast scalar
    c_scalar = Constant("c_scalar", shape=(), values=b"1234")
    c_scalar.broadcast((2,2))
    
    c3.slice([0], [1], [0])
    Constant.concatenate([c3], 0)
    c3.cast(DType.FLOAT16)
    c3.quantize_int8(1.0, 0)
    c3.unpack_int4()
    g.evaluate_math_graph()
    c3.extract_scalar()
    Graph.pack_constants([c3], "p")
    g.unpack_constant(c3, [(2,2)])
    c3.sparse_to_dense()
    c3.dense_to_sparse()

    # Printing
    g.print_topology_map()
    g.print_constants_by_size()
    g.print_op_frequency()
    g.trace_tensor_ops("in1")
    g.trace_origin("in1")
    g.trace_destiny("in1")
    g.dump_subgraph_netron([], "f")
    g.visualize_browser_canvas("id")
    n4.validate_attributes()
    Constant.compare_allclose(c3, c3)
    g.warn_implicit_broadcasting()
    g.identify_isolated_nodes()

    # Custom Ops
    g.register_custom_op_schema("dom", "op", {})
    g.inject_custom_node("op", "dom", [], [], {})
    g.delete_custom_node(n4)
    
    g.register_hook("h1", lambda x: None)
    g.trigger_hook("h1")
    g.wrap_unrecognized_domain("dom")
    g.unwrap_custom_op(n4, lambda x: None)
    n4.validate_custom_op(lambda x: None)
    
    # Walk
    list(g.walk(yield_type="tensor"))
    list(g.walk(yield_type="constant"))
    list(g.walk(yield_type="variable"))
    list(g.walk(direction="forward"))
    list(g.walk(mode="bfs"))

    # Missing branches
    # math nodes folding
    n_math = Node("Add", inputs=[c3, c3], outputs=[Variable("out_math")])
    g.add_node(n_math)
    g.fold_constants_math()
    
    # shape folding
    n_shape = Node("Shape", inputs=[c3], outputs=[Variable("out_shape")])
    g.add_node(n_shape)
    g.fold_constants_shape()
    
    # eliminate dropout
    n_drop = Node("Dropout", inputs=[v1], outputs=[Variable("out_drop")])
    g.add_node(n_drop)
    g.eliminate_dropout()
    
    # eliminate cast
    n_cast = Node("Cast", inputs=[c3], outputs=[Variable("out_cast", dtype=c3.dtype)])
    g.add_node(n_cast)
    g.eliminate_cast()
    
    # fuse sequential
    n_s1 = Node("Reshape", inputs=[v1], outputs=[Variable("res1")])
    n_s2 = Node("Reshape", inputs=[n_s1.outputs[0]], outputs=[Variable("res2")])
    g.add_node(n_s1)
    g.add_node(n_s2)
    g.fuse_sequential_reshapes()
    
    # minification missing output/input protection
    g.minification()

    # deduplicate missing match
    c_dup = Constant("c_dup", values=b"abc")
    g.add_tensor(c_dup)
    g.deduplicate_constants()

