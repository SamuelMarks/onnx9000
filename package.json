{
  "name": "onnx9000-monorepo",
  "version": "1.0.0",
  "packageManager": "pnpm@8.15.0",
  "private": true,
  "description": "Zero-dependency, WASM-First ONNX execution and MLOps ecosystem",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,js,json,md,yaml}\" && uv run ruff format",
    "prepare": "husky",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^28.0.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitest/coverage-v8": "^1.6.0",
    "assemblyscript": "^0.28.10",
    "esbuild": "^0.27.4",
    "eslint": "^9.0.0",
    "husky": "^9.0.11",
    "jsdom": "^29.0.0",
    "lint-staged": "^15.2.2",
    "playwright": "^1.58.2",
    "prettier": "^3.2.5",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.1",
    "vite": "5.4.11",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@onnx9000/iree-compiler": "workspace:^",
    "@onnx9000/iree-runtime": "workspace:^",
    "fflate": "^0.8.2"
  }
}
